# AI Team Leader Configuration Example
# Copy to settings.env and fill in your values

# ViciDial MySQL
VICIDIAL_DB_HOST=localhost
VICIDIAL_DB_NAME=asterisk
VICIDIAL_DB_USER=root
VICIDIAL_DB_PASS=YOUR_PASSWORD

# NVIDIA NIM AI
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm5

# Supervisor user (your ViciDial user ID)
SUPERVISOR_USER=6666

# Campaigns to monitor (comma-separated)
ACTIVE_CAMPAIGNS=2002,1007,2000,2001

# Thresholds
IDLE_ALERT_MINUTES=5
HOPPER_LOW_THRESHOLD=20

# Resource limits
MAX_CPU_PERCENT=80
MAX_MEMORY_MB=500
MAX_RUN_TIME_SECONDS=30
